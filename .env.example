# Copy this file to .env. GraphRAG Workbench runs entirely on this machine.

# OpenAI configuration
GRAPHRAG_COMPLETION_PROVIDER=openai
GRAPHRAG_COMPLETION_MODEL=gpt-5.6-luna
GRAPHRAG_COMPLETION_API_BASE=https://api.openai.com/v1
GRAPHRAG_EMBEDDING_PROVIDER=openai
GRAPHRAG_EMBEDDING_MODEL=text-embedding-3-small
GRAPHRAG_EMBEDDING_API_BASE=https://api.openai.com/v1
GRAPHRAG_API_KEY=<API_KEY>

# Ollama alternative. Replace the OpenAI values above with these values after
# installing Ollama and pulling models that support GraphRAG's structured JSON.
# Local models vary in reliability; GraphRAG may reject malformed output.
# GRAPHRAG_COMPLETION_PROVIDER=ollama
# GRAPHRAG_COMPLETION_MODEL=gemma4:latest
# GRAPHRAG_COMPLETION_API_BASE=http://127.0.0.1:11434
# GRAPHRAG_EMBEDDING_PROVIDER=ollama
# GRAPHRAG_EMBEDDING_MODEL=nomic-embed-text:latest
# GRAPHRAG_EMBEDDING_API_BASE=http://127.0.0.1:11434
# GRAPHRAG_API_KEY=ollama

# Performance tuning. The workbench resolves sensible defaults per provider
# (Ollama: concurrency 1, vector size 768 · hosted APIs: concurrency 4,
# vector size 1536), so these are only needed to override.
# GRAPHRAG_CONCURRENT_REQUESTS controls parallel LLM requests across graph
# extraction, community reports, and embeddings. GraphRAG's own default is 25;
# raise it once your API tier tolerates parallel traffic. If concurrent
# requests fail with a misleading 401, lower it again.
# GRAPHRAG_CONCURRENT_REQUESTS=4
# GRAPHRAG_EMBEDDING_VECTOR_SIZE must match the embedding model's output width
# (text-embedding-3-small: 1536, nomic-embed-text: 768).
# GRAPHRAG_EMBEDDING_VECTOR_SIZE=1536
